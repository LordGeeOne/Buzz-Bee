rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Any signed-in user can read user profiles (for search)
      allow read: if request.auth != null;
      // Owner can write anything on their own document
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId
        // Another participant may toggle ONLY the `connectionId` field on
        // this user's doc, when accepting a connection or disconnecting.
        // Allowed transitions:
        //   '' / missing  ->  '<sortedA>_<sortedB>' containing caller's uid
        //   '<id containing caller>' -> ''
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connectionId'])
          && (
            // Setting (accept): old empty/missing, new is a string whose
            // underscore-split parts include the caller.
            (
              resource.data.get('connectionId', '') == ''
              && request.resource.data.connectionId is string
              && request.resource.data.connectionId != ''
              && request.resource.data.connectionId.split('_').hasAny([request.auth.uid])
            )
            // Clearing (disconnect): new is empty, old contained caller.
            || (
              request.resource.data.get('connectionId', '') == ''
              && resource.data.get('connectionId', '') is string
              && resource.data.connectionId.split('_').hasAny([request.auth.uid])
            )
          )
        )
      );

      match /requests/{requestId} {
        // Owner can read their own requests
        allow read: if request.auth != null && request.auth.uid == userId;
        // Any signed-in user can send a request, but only as themselves
        // (requestId must equal their uid, and fromUid must match).
        allow create, update: if request.auth != null
                              && request.auth.uid == requestId
                              && request.resource.data.fromUid == request.auth.uid;
        // Owner can delete their own requests (accept/reject).
        // Sender can also delete their own pending request (cancel/unlike).
        allow delete: if request.auth != null
                      && (request.auth.uid == userId
                          || request.auth.uid == requestId);
      }

      match /notifications/{notificationId} {
        // Owner can read/update (mark read) / delete their own notifications
        allow read, update, delete: if request.auth != null
                                    && request.auth.uid == userId;
        // Any signed-in user can create a notification addressed to another user
        allow create: if request.auth != null;
      }
    }

    match /connections/{connectionId} {
      // Create: caller must be one of the two users in the new doc AND the
      // other user must already have a pending request from the caller's
      // perspective (i.e. the caller is accepting an incoming request).
      // This prevents a malicious client from fabricating a connection with
      // any user without their consent.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.users.size() == 2
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid)/requests/$(
                         request.resource.data.users[0] == request.auth.uid
                           ? request.resource.data.users[1]
                           : request.resource.data.users[0]
                       ));
      // Read (get/list): caller must be a participant. Allow reads of
      // non-existent docs too so client-side existence checks (e.g. the
      // sendRequest transaction's first `tx.get(connRef)`) don't trip the
      // rule on a null `resource`.
      allow read: if request.auth != null
                  && (resource == null
                      || resource.data.get('users', []).hasAny([request.auth.uid]));
      // Update/delete: caller must be a participant in the existing doc.
      // When the update touches `lastMessage`, its `fromUid` must equal the
      // caller — prevents spoofing the other user's last-message preview.
      allow update: if request.auth != null
                    && resource.data.get('users', []).hasAny([request.auth.uid])
                    && (
                      !request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastMessage'])
                      || request.resource.data.lastMessage.fromUid == request.auth.uid
                    );
      allow delete: if request.auth != null
                    && resource.data.get('users', []).hasAny([request.auth.uid]);

      match /messages/{messageId} {
        // Read: any participant.
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/connections/$(connectionId)).data.users;
        // Create: any participant; the message must claim them as the sender.
        allow create: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/connections/$(connectionId)).data.users
                      && request.resource.data.fromUid == request.auth.uid;
        // Update: three permitted classes of writes:
        //   1. SENDER content edits (e.g. two-phase voice/image upload
        //      completing, plus edit/delete-for-everyone). Restricted to
        //      a 1h window after the original send and forbidden from
        //      changing immutable fields (fromUid, type, timestamp).
        //   2. RECIPIENT stamping ephemeral-media TTL fields
        //      (deliveredAt / seenAt / expireAt) and nothing else.
        //   3. ANY participant adding/removing their own reaction in the
        //      `reactions.<uid>` map slot \u2014 no time limit, no other
        //      fields touched.
        allow update: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/connections/$(connectionId)).data.users
                      && (
                        // (1) sender editing within 1h window. Use .get()
                        // with a `request.time` default so that a missing or
                        // server-pending `timestamp` (which would crash on
                        // `.toMillis()`) doesn't blanket-fail the rule.
                        (
                          request.auth.uid == resource.data.fromUid
                          && request.time.toMillis() - resource.data.get('timestamp', request.time).toMillis() < 60 * 60 * 1000
                          && !request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasAny(['fromUid', 'type', 'timestamp', 'deliveredAt', 'seenAt'])
                        )
                        // (2) recipient stamping TTL fields only
                        || (
                          request.auth.uid != resource.data.fromUid
                          && request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasOnly(['deliveredAt', 'seenAt', 'expireAt'])
                        )
                        // (3) any participant toggling their own reaction
                        || (
                          request.resource.data.diff(resource.data)
                              .affectedKeys()
                              .hasOnly(['reactions'])
                          && request.resource.data.get('reactions', {})
                              .diff(resource.data.get('reactions', {}))
                              .affectedKeys()
                              .hasOnly([request.auth.uid])
                        )
                      );
        // Delete: server-side only (TTL / cleanup CF). Clients never delete
        // message docs directly.
        allow delete: if false;
      }

      // Voice-call signaling: WebRTC offer/answer + ICE candidates.
      // Only the two connection participants can read/write call docs.
      match /calls/{callId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/connections/$(connectionId)).data.users;

        match /callerCandidates/{candidateId} {
          allow read, write: if request.auth != null
                             && request.auth.uid in
                                get(/databases/$(database)/documents/connections/$(connectionId)).data.users;
        }
        match /calleeCandidates/{candidateId} {
          allow read, write: if request.auth != null
                             && request.auth.uid in
                                get(/databases/$(database)/documents/connections/$(connectionId)).data.users;
        }
      }
    }

    match /usernames/{username} {
      // Anyone signed in can check if a username exists
      allow read: if request.auth != null;
      // Only allow create if the doc doesn't exist yet and uid matches
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Allow update if the caller already owns this username
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
    }
  }
}
