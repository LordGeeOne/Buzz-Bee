rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Any signed-in user can read user profiles (for search)
      allow read: if request.auth != null;
      // Owner can write anything on their own document
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId
        // Another participant may toggle ONLY the `connectionId` field on
        // this user's doc, when accepting a connection or disconnecting.
        // Allowed transitions:
        //   '' / missing  ->  '<sortedA>_<sortedB>' containing caller's uid
        //   '<id containing caller>' -> ''
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['connectionId'])
          && (
            // Setting (accept): old empty/missing, new is a string whose
            // underscore-split parts include the caller.
            (
              resource.data.get('connectionId', '') == ''
              && request.resource.data.connectionId is string
              && request.resource.data.connectionId != ''
              && request.resource.data.connectionId.split('_').hasAny([request.auth.uid])
            )
            // Clearing (disconnect): new is empty, old contained caller.
            || (
              request.resource.data.get('connectionId', '') == ''
              && resource.data.get('connectionId', '') is string
              && resource.data.connectionId.split('_').hasAny([request.auth.uid])
            )
          )
        )
      );

      match /requests/{requestId} {
        // Owner can read their own requests
        allow read: if request.auth != null && request.auth.uid == userId;
        // Any signed-in user can send a request, but only as themselves
        // (requestId must equal their uid, and fromUid must match).
        allow create, update: if request.auth != null
                              && request.auth.uid == requestId
                              && request.resource.data.fromUid == request.auth.uid;
        // Owner can delete their own requests (accept/reject).
        // Sender can also delete their own pending request (cancel/unlike).
        allow delete: if request.auth != null
                      && (request.auth.uid == userId
                          || request.auth.uid == requestId);
      }

      match /notifications/{notificationId} {
        // Owner can read/update (mark read) / delete their own notifications
        allow read, update, delete: if request.auth != null
                                    && request.auth.uid == userId;
        // Any signed-in user can create a notification addressed to another user
        allow create: if request.auth != null;
      }
    }

    match /connections/{connectionId} {
      // Create: caller must be one of the two users in the new doc
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.users
                    && request.resource.data.users.size() == 2;
      // Read (get/list): caller must be a participant.
      // Use .get() with default to safely handle docs missing `users`.
      allow read: if request.auth != null
                  && resource.data.get('users', []).hasAny([request.auth.uid]);
      // Update/delete: caller must be a participant in the existing doc.
      allow update: if request.auth != null
                    && resource.data.get('users', []).hasAny([request.auth.uid]);
      allow delete: if request.auth != null
                    && resource.data.get('users', []).hasAny([request.auth.uid]);

      match /messages/{messageId} {
        // Only connection participants can access messages
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/connections/$(connectionId)).data.users;
      }

      // Voice-call signaling: WebRTC offer/answer + ICE candidates.
      // Only the two connection participants can read/write call docs.
      match /calls/{callId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in
                              get(/databases/$(database)/documents/connections/$(connectionId)).data.users;

        match /callerCandidates/{candidateId} {
          allow read, write: if request.auth != null
                             && request.auth.uid in
                                get(/databases/$(database)/documents/connections/$(connectionId)).data.users;
        }
        match /calleeCandidates/{candidateId} {
          allow read, write: if request.auth != null
                             && request.auth.uid in
                                get(/databases/$(database)/documents/connections/$(connectionId)).data.users;
        }
      }
    }

    match /usernames/{username} {
      // Anyone signed in can check if a username exists
      allow read: if request.auth != null;
      // Only allow create if the doc doesn't exist yet and uid matches
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Allow update if the caller already owns this username
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
    }
  }
}
