rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Voice messages are scoped to a connection. Both participants must
    // be in the connection's `users` array (mirrors the Firestore rule).
    match /voice/{connectionId}/{file} {
      function isParticipant() {
        return request.auth != null
          && firestore.exists(
               /databases/(default)/documents/connections/$(connectionId)
             )
          && request.auth.uid in firestore.get(
               /databases/(default)/documents/connections/$(connectionId)
             ).data.users;
      }

      allow read: if isParticipant();
      allow write: if isParticipant()
                   && request.resource.size < 1 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // Profile gallery photos. Anyone signed in can view; only the
    // owner can upload/delete their own files.
    match /gallery/{uid}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (request.resource == null
                       || (request.resource.size < 8 * 1024 * 1024
                           && request.resource.contentType.matches('image/.*')));
    }

    // Profile avatars (the main profile photo). Anyone signed in can
    // view; only the owner can upload/delete their own avatar.
    match /avatars/{uid}/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && (request.resource == null
                       || (request.resource.size < 8 * 1024 * 1024
                           && request.resource.contentType.matches('image/.*')));
    }
  }
}
